// warket-ios — Supabase credentials TEMPLATE
//
// Copy this file to `Secrets.xcconfig` (same folder) and paste your real values
// from the web app's .env:
//   VITE_SUPABASE_URL      -> SUPABASE_URL
//   VITE_SUPABASE_ANON_KEY -> SUPABASE_ANON_KEY
//
// The anon key is safe to ship (RLS protects the data), but we still keep it out
// of git. `Secrets.xcconfig` is gitignored.
//
// ⚠️ xcconfig gotcha: "//" starts a comment — even inside a URL. To preserve the
// "https://" scheme we split the slashes with $() which expands to nothing.

SUPABASE_URL = https:/$()/your-project.supabase.co
SUPABASE_ANON_KEY = your-anon-key-here
